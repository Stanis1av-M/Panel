<Page x:Class="Panel.Views.Pages.DictionariesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление справочниками" 
      Background="#F0F2F5" 
      FontFamily="Segoe UI"
      TextOptions.TextFormattingMode="Display" 
      SnapsToDevicePixels="True">

    <Page.Resources>
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DirectoryLinkStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2F3640"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="brd" Background="Transparent" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#00A8FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#DCDDE1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#636E72"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,0,0,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F5F6FA"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20" UseLayoutRounding="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="10" Margin="0,0,20,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="СПРАВОЧНИКИ" 
                           FontWeight="Bold" 
                           FontSize="11" 
                           Foreground="#A4B0BE" 
                           Margin="15,10,0,15" />

                <ListBox x:Name="lstDictionaries" 
                         BorderThickness="0" 
                         Background="Transparent" 
                         ItemContainerStyle="{StaticResource DirectoryLinkStyle}"
                         SelectionChanged="LstDictionaries_SelectionChanged">
                    <ListBoxItem Content="📂 Категории" Tag="Categories"/>
                    <ListBoxItem Content="🏭 Производители" Tag="Manufacturers"/>
                    <ListBoxItem Content="🚚 Поставщики" Tag="Suppliers"/>
                    <ListBoxItem Content="📝 Статусы заказов" Tag="Statuses"/>
                    <ListBoxItem Content="📦 Способы доставки" Tag="Delivery"/>
                    <ListBoxItem Content="💳 Способы оплаты" Tag="Payment"/>
                </ListBox>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="12" Margin="0,0,0,15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
                </Border.Effect>
                <DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnAdd" Content="➕ Добавить" Width="130" 
                                Background="#4CD137" Style="{StaticResource ControlButtonStyle}"
                                Click="BtnAdd_Click" Margin="0,0,12,0"/>

                        <Button x:Name="btnSave" Content="💾 Сохранить изменения" Width="190" 
                                Background="#00A8FF" Style="{StaticResource ControlButtonStyle}"
                                Click="BtnSave_Click"/>
                    </StackPanel>

                    <Button x:Name="btnDelete" Content="🗑️ Удалить" HorizontalAlignment="Right" Width="110" 
                            Background="#E84118" Style="{StaticResource ControlButtonStyle}"
                            Click="BtnDelete_Click"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
                </Border.Effect>

                <DataGrid x:Name="GridData" 
                          AutoGenerateColumns="True" 
                          AutoGeneratingColumn="GridData_AutoGeneratingColumn" 
                          Background="Transparent" 
                          BorderThickness="0" 
                          RowHeight="48" 
                          CanUserAddRows="False"
                          IsReadOnly="False"
                          GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="#F5F6FA"
                          ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                          SelectionMode="Single">

                    <DataGrid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#2D3436"/>
                        </Style>

                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>
                    </DataGrid.Resources>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Page>