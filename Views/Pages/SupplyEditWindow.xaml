<Window x:Class="Panel.Views.SupplyEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая поставка" Height="500" Width="750" 
        WindowStartupLocation="CenterOwner" Background="#F0F2F5" FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Выберите поставщика:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbSupplier" Width="250" Height="30" DisplayMemberPath="Name" SelectedValuePath="SupplierId"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Bottom">
                    <Button Content="➕ Добавить товар в список" Width="180" Height="30" Click="BtnAddItem_Click" Background="#00A8FF" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
            <DataGrid x:Name="GridSupplyItems" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="*"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="Цена закуп." Binding="{Binding Price, StringFormat=\{0:N2\} руб.}" Width="120"/>
                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="❌" Click="BtnRemoveItem_Click" Background="Transparent" BorderThickness="0" Foreground="Red" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="100" Height="35" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="💾 Создать поставку" Width="160" Height="35" Background="#4CD137" Foreground="White" FontWeight="Bold" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>