<Window x:Class="Panel.Views.OrderStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена статуса заказа" Height="220" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F2F5" FontFamily="Segoe UI">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock x:Name="txtOrderInfo" Text="Заказ №..." FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Выберите новый статус:" Margin="0,0,0,5" Foreground="#2F3640"/>
            <ComboBox x:Name="cmbNewStatus" Height="35" DisplayMemberPath="Name" SelectedValuePath="OrderStatusId"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                <Button Content="Отмена" Width="100" Height="35" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="💾 Сохранить" Width="120" Height="35" Background="#4CD137" Foreground="White" FontWeight="Bold" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>