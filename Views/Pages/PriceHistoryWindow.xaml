<Window x:Class="Panel.Views.PriceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="История изменения цен" Height="450" Width="800" 
        WindowStartupLocation="CenterScreen" Background="#F0F2F5" FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ИСТОРИЯ ИЗМЕНЕНИЙ ЦЕН" FontSize="18" FontWeight="Bold" Foreground="#2F3640" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>

            <DataGrid x:Name="GridHistory" AutoGenerateColumns="False" IsReadOnly="True" 
                      Background="Transparent" BorderThickness="0" RowHeight="40" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="*"/>
                    <DataGridTextColumn Header="Старая цена" Binding="{Binding OldPrice, StringFormat=\{0:N2\} руб.}" Width="120"/>
                    <DataGridTextColumn Header="Новая цена" Binding="{Binding NewPrice, StringFormat=\{0:N2\} руб.}" Width="120"/>
                    <DataGridTextColumn Header="Дата изменения" Binding="{Binding ChangeAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>