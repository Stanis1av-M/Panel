<Window x:Class="Panel.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка товара" Height="580" Width="750"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F2F5" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveBtnStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="#4CD137"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#44BD32"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelBtnStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="#A4B0BE"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#747D8C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImageBtnStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="#00A8FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0097E6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2F3640"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="ИНФОРМАЦИЯ О ТОВАРЕ" FontSize="16" FontWeight="Bold" Foreground="#A4B0BE" Margin="0,0,0,10"/>

                <TextBlock Text="Артикул:" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="txtArticle" Height="35" Padding="8,6" FontSize="14" BorderBrush="#DCDDE1" MaxLength="8"/>
                    <Button Grid.Column="1" x:Name="btnGenerateArticle" Content="Сгенерировать" Margin="10,0,0,0" 
            Style="{StaticResource ImageBtnStyle}" Click="BtnGenerateArticle_Click"/>
                </Grid>

                <TextBlock Text="Название товара:" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtName" Height="35" Padding="8,6" FontSize="14" MaxLength="50"/>

                <TextBlock Text="Категория:" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="cmbCategory" Height="35" FontSize="14" BorderBrush="#DCDDE1" 
                          DisplayMemberPath="Name" SelectedValuePath="CategoryId"/>

                <TextBlock Text="Производитель:" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="cmbManufacturer" Height="35" FontSize="14" BorderBrush="#DCDDE1" 
                          DisplayMemberPath="Name" SelectedValuePath="ManufactureId"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Цена (руб):" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtPrice" Height="35" Padding="8,6" FontSize="14" MaxLength="7" PreviewTextInput="NumberValidationTextBox"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="На складе (шт):" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtStock" Height="35" Padding="8,6" FontSize="14" MaxLength="2" PreviewTextInput="NumberValidationTextBox"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ФОТОГРАФИЯ" FontSize="16" FontWeight="Bold" Foreground="#A4B0BE" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <Border Width="200" Height="200" BorderBrush="#F5F6FA" BorderThickness="2" Background="#F5F6FA" CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="📷" FontSize="50" Foreground="#DCDDE1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image x:Name="imgPreview" Stretch="UniformToFill"/>
                    </Grid>
                </Border>

                <Button x:Name="btnSelectImage" Content="Выбрать изображение" Height="40" Margin="10,20,10,0" 
                        Style="{StaticResource ImageBtnStyle}" Click="BtnSelectImage_Click"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnCancel" Content="Отмена" Width="120" Height="40" Margin="0,0,15,0" 
                    Style="{StaticResource CancelBtnStyle}" Click="BtnCancel_Click"/>

            <Button x:Name="btnSave" Content="💾 Сохранить" Width="150" Height="40" 
                    Style="{StaticResource SaveBtnStyle}" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>