<Page x:Class="Panel.Views.Pages.SuppliesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SuppliesPage" Background="#F0F2F5" FontFamily="Segoe UI"
      TextOptions.TextFormattingMode="Display" SnapsToDevicePixels="True">

    <Page.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddBtnStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="#4CD137"/>
        </Style>
        <Style x:Key="ActionBtnStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="#00A8FF"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="➕ Новая поставка" Width="160" Style="{StaticResource AddBtnStyle}" Click="BtnAddSupply_Click" Margin="0,0,10,0"/>
                    <Button Content="✅ Завершить" Width="130" Style="{StaticResource ActionBtnStyle}" Click="BtnCompleteSupply_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="📈 История цен" Width="130" Style="{StaticResource ActionBtnStyle}" Background="#747D8C" Click="BtnPriceHistory_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
            <DataGrid x:Name="GridSupplies" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                      Background="Transparent" BorderThickness="0" RowHeight="50" GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding SupplyId}" Width="60"/>
                    <DataGridTextColumn Header="Дата поставки" Binding="{Binding SupplyDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="150"/>
                    <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier.Name}" Width="*"/>

                    <DataGridTemplateColumn Header="Статус" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#F5F6FA" CornerRadius="5" Padding="8,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Status}" FontWeight="SemiBold" Foreground="#2F3640"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>