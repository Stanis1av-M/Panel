<Page x:Class="Panel.Views.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="OrdersPage" Background="#F0F2F5" FontFamily="Segoe UI"
      TextOptions.TextFormattingMode="Display" 
      TextOptions.TextRenderingMode="ClearType">

    <Page.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtnStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="#00A8FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0097E6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResetBtnStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="#747D8C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#57606F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Поиск (Клиент/№):" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5" Foreground="#A4B0BE"/>
                    <TextBox x:Name="txtSearch" Width="180" Height="32" Padding="8,5" MaxLength="65" 
                             TextChanged="FilterChanged" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="Статус заказа:" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5" Foreground="#A4B0BE"/>
                    <ComboBox x:Name="cmbStatus" Width="140" Height="32" 
                              SelectionChanged="FilterChanged" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                    <TextBlock Text="Сортировать по:" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5" Foreground="#A4B0BE"/>
                    <ComboBox x:Name="cmbSort" Width="150" Height="32" 
                              SelectionChanged="FilterChanged" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Сначала новые" IsSelected="True"/>
                        <ComboBoxItem Content="Сначала старые"/>
                        <ComboBoxItem Content="Сумма (возр.)"/>
                        <ComboBoxItem Content="Сумма (убыв.)"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="btnUpdateStatus" Content="🔄 Изменить статус" Width="135" 
                            Style="{StaticResource ActionBtnStyle}" Click="BtnUpdateStatus_Click" Margin="0,0,10,0"/>

                    <Button x:Name="btnReset" Content="❌ Сброс" Width="100" 
                            Style="{StaticResource ResetBtnStyle}" Click="BtnReset_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>

            <DataGrid x:Name="GridOrders" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionMode="Single" Background="Transparent" BorderThickness="0"
                      RowHeight="55" HeadersVisibility="Column" GridLinesVisibility="None"
                      SnapsToDevicePixels="True">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#636E72"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,0,0,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F5F6FA"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding OrderId}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2D3436"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="ДАТА СОЗДАНИЯ" Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2D3436"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="КЛИЕНТ / ПОЧТА" Binding="{Binding User.FullName}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2D3436"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="ИТОГО" Binding="{Binding TotalAmount, StringFormat=\{0:N2\} руб.}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#2D3436"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="СТАТУС" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#F5F6FA" CornerRadius="6" Padding="8,4" Margin="5,8" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding OrderStatus.Name}" FontSize="12" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                                               FontWeight="SemiBold" Foreground="#2F3640"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>