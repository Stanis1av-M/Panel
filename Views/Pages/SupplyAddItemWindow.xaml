<Window x:Class="Panel.Views.SupplyAddItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление позиции" 
        Width="400" SizeToContent="Height" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" 
        Background="#F0F2F5" FontFamily="Segoe UI">

    <Border Padding="25" Background="White">
        <StackPanel>
            <TextBlock Text="ДОБАВЛЕНИЕ ПОЗИЦИИ" FontWeight="Bold" FontSize="15" Foreground="#2F3640" Margin="0,0,0,20"/>

            <TextBlock Text="Выберите товар:" Margin="0,0,0,5" Foreground="#A4B0BE" FontWeight="SemiBold" FontSize="11"/>
            <ComboBox x:Name="cmbProduct" Height="35" DisplayMemberPath="Name" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Кол-во (до 999):" Margin="0,0,0,5" Foreground="#A4B0BE" FontWeight="SemiBold" FontSize="11"/>
                    <TextBox x:Name="txtQuantity" Height="35" MaxLength="3" 
                             VerticalContentAlignment="Center" Padding="5,0" 
                             PreviewTextInput="NumberValidation" TextChanged="CalculateTotal"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Цена за 1 шт.:" Margin="0,0,0,5" Foreground="#A4B0BE" FontWeight="SemiBold" FontSize="11"/>
                    <TextBox x:Name="txtUnitPrice" Height="35" MaxLength="10" 
                             VerticalContentAlignment="Center" Padding="5,0" 
                             PreviewTextInput="DecimalValidation" TextChanged="CalculateTotal"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Итоговая цена закупа (рассчитано):" Margin="0,0,0,5" Foreground="#A4B0BE" FontWeight="SemiBold" FontSize="11"/>
            <TextBox x:Name="txtTotalPrice" Height="35" Background="#F5F6FA" IsReadOnly="True" 
                     FontWeight="Bold" Foreground="#00A8FF" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,20"/>

            <Separator Margin="0,0,0,20" Background="#F5F6FA"/>

            <Button Content="✅ Добавить в список" Height="40" Background="#4CD137" Foreground="White" 
                    FontWeight="Bold" Cursor="Hand" Click="BtnAdd_Click"/>
        </StackPanel>
    </Border>
</Window>