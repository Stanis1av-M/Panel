<Page x:Class="Panel.Views.Pages.AddUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавление пользователя" Background="#F0F2F5" FontFamily="Segoe UI"
      TextOptions.TextFormattingMode="Display" SnapsToDevicePixels="True">

    <Grid Margin="30">
        <Border Background="White" CornerRadius="15" Padding="30" 
                MaxWidth="800" VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="ДОБАВЛЕНИЕ СОТРУДНИКА" FontWeight="Bold" FontSize="20" Margin="0,0,0,25" Foreground="#2F3640"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,20">
                            <TextBlock Text="Полное имя (ФИО) *" Foreground="#A4B0BE" Margin="0,0,0,5" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="txtFullName" Height="40" VerticalContentAlignment="Center" Padding="10,0" MaxLength="100"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,20">
                            <TextBlock Text="Email (логин) *" Foreground="#A4B0BE" Margin="0,0,0,5" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="txtEmail" Height="40" VerticalContentAlignment="Center" Padding="10,0" MaxLength="100"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,20">
                            <TextBlock Text="Телефон" Foreground="#A4B0BE" Margin="0,0,0,5" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="txtPhone" Height="40" VerticalContentAlignment="Center" Padding="10,0" 
                                     MaxLength="20"
                                     PreviewTextInput="PhoneTextBox_PreviewTextInput"
                                     DataObject.Pasting="PhoneTextBox_Pasting"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,20">
                            <TextBlock Text="Должность (Роль) *" Foreground="#A4B0BE" Margin="0,0,0,5" FontWeight="Bold" FontSize="11"/>
                            <ComboBox x:Name="cmbRole" Height="40" VerticalContentAlignment="Center" Padding="10,0"/>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,10,0,25" Background="#F5F6FA"/>

                    <TextBlock Text="БЕЗОПАСНОСТЬ" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="#2F3640"/>

                    <StackPanel MaxWidth="400" HorizontalAlignment="Left">
                        <TextBlock Text="Пароль * (макс. 30 символов)" Foreground="#A4B0BE" Margin="0,0,0,5" FontWeight="Bold" FontSize="11"/>
                        <PasswordBox x:Name="txtPassword" Height="40" VerticalContentAlignment="Center" Padding="10,0"
                                     PasswordChanged="txtPassword_PasswordChanged"/>
                    </StackPanel>

                    <Button Content="➕ Добавить сотрудника" Click="BtnSave_Click" HorizontalAlignment="Left"
                            Margin="0,40,0,0" Width="240" Height="45" Background="#00A8FF" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>