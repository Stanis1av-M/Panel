<Window x:Class="Panel.Views.AddReferenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление записи" 
        Width="400" 
        SizeToContent="Height" 
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize" 
        Background="#F0F2F5"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock x:Name="txtTitle" Text="ДОБАВЛЕНИЕ" FontSize="16" FontWeight="Bold" Foreground="#2F3640" Margin="0,0,0,20"/>

            <StackPanel x:Name="panelName" Margin="0,0,0,15">
                <TextBlock Text="Наименование:" Margin="0,0,0,5" Foreground="#A4B0BE" FontWeight="Bold" FontSize="11"/>
                <TextBox x:Name="txtName" Height="32" VerticalContentAlignment="Center" MaxLength="1000000" Padding="5,0"/>
            </StackPanel>

            <StackPanel x:Name="panelCountry" Margin="0,0,0,15" Visibility="Collapsed">
                <TextBlock Text="Страна:" Margin="0,0,0,5" Foreground="#A4B0BE" FontWeight="Bold" FontSize="11"/>
                <TextBox x:Name="txtCountry" Height="32" VerticalContentAlignment="Center" MaxLength="1000000" Padding="5,0"/>
            </StackPanel>

            <StackPanel x:Name="panelSupplier" Visibility="Collapsed">
                <TextBlock Text="Контакты:" Margin="0,0,0,5" Foreground="#A4B0BE" FontWeight="Bold" FontSize="11"/>
                <TextBox x:Name="txtContacts" Height="32" Margin="0,0,0,15" VerticalContentAlignment="Center" MaxLength="1000000" Padding="5,0"/>
                <TextBlock Text="Адрес:" Margin="0,0,0,5" Foreground="#A4B0BE" FontWeight="Bold" FontSize="11"/>
                <TextBox x:Name="txtAddress" Height="32" Margin="0,0,0,15" VerticalContentAlignment="Center" MaxLength="1000000" Padding="5,0"/>
            </StackPanel>
            <StackPanel x:Name="panelPrice" Margin="0,0,0,15" Visibility="Collapsed">
                <TextBlock Text="Стоимость доставки (руб.):" Margin="0,0,0,5" Foreground="#A4B0BE" FontWeight="Bold" FontSize="11"/>
                <TextBox x:Name="txtPrice" Height="32" VerticalContentAlignment="Center" Padding="5,0"
             MaxLength="7" 
             PreviewTextInput="NumericTextBox_PreviewTextInput"
             DataObject.Pasting="NumericTextBox_Pasting"/>
            </StackPanel>

            <StackPanel x:Name="panelActive" Orientation="Horizontal" Margin="0,0,0,20" Visibility="Collapsed">
                <CheckBox x:Name="chkIsActive" IsChecked="True" VerticalAlignment="Center"/>
                <TextBlock Text="Доступен для выбора" Margin="10,0,0,0" VerticalAlignment="Center" 
                           Foreground="#2F3640" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Отмена" Width="100" Height="35" Margin="0,0,10,0" Click="BtnCancel_Click" Background="#747D8C" Foreground="White" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="✅ Сохранить" Width="120" Height="35" Click="BtnSave_Click" Background="#4CD137" Foreground="White" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>