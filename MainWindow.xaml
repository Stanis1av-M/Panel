<Window x:Class="Panel.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apex Shop - Панель управления" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5"
        FontFamily="Segoe UI"
        Icon="/ico/app_icon.ico">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A4B0BE"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="15,4"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3F4752"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Margin="10,20,10,10" Padding="10">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3F4752"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AdminButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Foreground" Value="#E1B12C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3F4752"/>
                    <Setter Property="Foreground" Value="#FBC531"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Foreground" Value="#FF6B81"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4757"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2F3640" Grid.Column="0" Panel.ZIndex="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2" Direction="0"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button x:Name="btnProfile" Style="{StaticResource ProfileButtonStyle}" Click="BtnProfile_Click" Grid.Row="0">
                    <StackPanel>
                        <Border Width="70" Height="70" CornerRadius="35" Background="#3F4752" Margin="0,0,0,10">
                            <TextBlock Text="👤" FontSize="35" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#A4B0BE"/>
                        </Border>
                        <TextBlock x:Name="txtUserName" Text="Имя Пользователя" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock x:Name="txtUserRole" Text="Роль" Foreground="#7ED6DF" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock Text="настроить профиль" Foreground="#57606f" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button x:Name="btnProducts" Content="📦  Товары" Style="{StaticResource MenuButtonStyle}" Click="BtnProducts_Click"/>
                    <Button x:Name="btnOrders" Content="🛒  Заказы" Style="{StaticResource MenuButtonStyle}" Click="btnOrders_Click_1"/>
                    <Button x:Name="btnSupplies" Content="🚚  Поставки" Style="{StaticResource MenuButtonStyle}" Click="btnSupplies_Click"/>
                    <Button x:Name="btnInventory" Content="📊  Склад" Style="{StaticResource MenuButtonStyle}" Click="BtnInventory_Click"/>

                    <Separator Margin="20,15" Background="#3F4752"/>

                    <Button x:Name="btnAdminPanel" Content="⚙️  Справочники" Style="{StaticResource AdminButtonStyle}" Click="btnAdminPanel_Click"/>
                    <Button x:Name="btnAddUser" Content="👥  Сотрудники" Style="{StaticResource AdminButtonStyle}" Click="BtnAddUser_Click"/>
                </StackPanel>

                <Button Grid.Row="2" x:Name="btnLogout" Content="🚪  Выйти" Margin="15,0,15,20" Style="{StaticResource LogoutButtonStyle}" Click="BtnLogout_Click"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="10"/>
        </Border>

    </Grid>
</Window>